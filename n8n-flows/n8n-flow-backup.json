        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"snippet\": {\n    \"parentGroupId\": \"{{$node[\"Set Config\"].json[\"target_pg_id\"]}}\",\n    \"processGroups\": {\n      \"{{$node[\"Set Config\"].json[\"target_pg_id\"]}}\": { \"revision\": { \"version\": 0 } }\n    }\n  }\n}",
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-4b6c-cdef-ghij12345678",
