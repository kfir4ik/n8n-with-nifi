      "parameters": {
        "method": "POST",
        "url": "=http://{{$node[\"Set Config\"].json[\"nifi_host\"]}}:{{$node[\"Set Config\"].json[\"nifi_port\"]}}/nifi-api/process-groups/{{$node[\"Set Config\"].json[\"target_pg_id\"]}}/templates",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": \"Backup_{{$now.format('yyyy-MM-dd')}}\",\n  \"description\": \"Automated n8n Backup\",\n  \"snippetId\": \"{{$node[\"Create Snippet\"].json[\"snippet\"][\"id\"]}}\"\n}",
        "options": {}
      },
      "id": "c3d4e5f6-a7b8-4c7d-defg-hijk12345678",
